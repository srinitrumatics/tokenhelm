# EditorConfig — https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.py]
indent_size = 4
max_line_length = 100

[*.{yml,yaml}]
indent_size = 2

[*.{json,json5}]
indent_size = 2

[*.toml]
indent_size = 4

[*.md]
indent_size = 2
trim_trailing_whitespace = false  # trailing whitespace can be a hard line break in Markdown

[Makefile]
indent_style = tab
