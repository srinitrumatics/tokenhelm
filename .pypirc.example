# Example ~/.pypirc for MANUAL uploads (local/dev only).
#
# Preferred path is Trusted Publishing (OIDC) via GitHub Actions — see docs/releasing.md —
# which needs NO tokens at all. Use this file only for ad-hoc local uploads.
#
# Create scoped API tokens at:
#   PyPI:     https://pypi.org/manage/account/token/
#   TestPyPI: https://test.pypi.org/manage/account/token/
# Never commit a real token. Copy this to ~/.pypirc and fill in the values.

[distutils]
index-servers =
    pypi
    testpypi

[pypi]
  repository = https://upload.pypi.org/legacy/
  username = __token__
  password = pypi-REPLACE_WITH_YOUR_PYPI_TOKEN

[testpypi]
  repository = https://test.pypi.org/legacy/
  username = __token__
  password = pypi-REPLACE_WITH_YOUR_TESTPYPI_TOKEN
